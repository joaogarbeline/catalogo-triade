# ---- Banco de Dados ----
POSTGRES_USER=triade
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=catalogo_triade
DATABASE_URL=postgresql://triade:troque-esta-senha@db:5432/catalogo_triade?schema=public

# ---- Aplicação ----
# Domínio oficial de produção. Usado para montar links de compartilhamento (/c/[hash])
NEXT_PUBLIC_BASE_URL=https://catalogo.performancetriade.com.br

# Segredo usado para assinar o cookie de sessão do admin (gere um valor aleatório forte)
JWT_SECRET=troque-este-segredo-em-producao

# ---- Seed inicial do admin (usado apenas por prisma/seed.ts) ----
ADMIN_EMAIL=admin@performancetriade.com.br
ADMIN_PASSWORD=troque-esta-senha
